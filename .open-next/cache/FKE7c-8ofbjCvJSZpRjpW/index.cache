-cyan-500/10 rounded-full flex items-center justify-center mb-3 border border-current/20 relative z-10\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-shield-alert w-7 h-7 text-cyan-400\" aria-hidden=\"true\"><path d=\"M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z\"></path><path d=\"M12 8v4\"></path><path d=\"M12 16h.01\"></path></svg></div><h3 class=\"text-slate-100 mb-2 tracking-wide relative z-10\">Weak Credentials</h3></div></div><div class=\"absolute top-full left-1/2 -translate-x-1/2 mt-4 w-64 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none z-20\"><div class=\"bg-slate-950/95 backdrop-blur-md border rounded-lg p-4 shadow-2xl\"><div class=\"absolute -top-2 left-1/2 -translate-x-1/2 w-4 h-4 rotate-45\"></div><p class=\"text-slate-300 text-sm relative z-10\">later...</p></div></div></div><div class=\"relative w-50 aspect-square group\"><div class=\"\n            absolute inset-0\n            bg-slate-900/50\n            backdrop-blur-m\n            transition-all\n            duration-300\n            overflow-hidden\n            border-2 border-cyan-400\n            flex justify-center items-center\n            rotate-45\n          \" style=\"clip-path:polygon(30% 0%, 70% 0%, 100% 30%, 100% 70%, 70% 100%, 30% 100%, 0% 70%, 0% 30%)\"></div><div class=\"   absolute inset-0   flex flex-col items-center justify-center p-6 text-center   rotate-45 group   \" style=\"clip-path:polygon(30% 0%, 70% 0%, 100% 30%, 100% 70%, 70% 100%, 30% 100%, 0% 70%, 0% 30%)\"><div class=\"\n              absolute inset-0\n              bg-gradient-to-b from-transparent via-white/5 to-transparent -translate-y-full\n              group-hover:translate-y-full \n              transition-transform duration-1000\n              pointer-events-none\n            \"></div><div class=\"-rotate-45 flex flex-col items-center justify-center\"><div class=\"w-14 h-14 bg-cyan-500/10 rounded-full flex items-center justify-center mb-3 border border-current/20 relative z-10\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-timer w-7 h-7 text-cyan-400\" aria-hidden=\"true\"><line x1=\"10\" x2=\"14\" y1=\"2\" y2=\"2\"></line><line x1=\"12\" x2=\"15\" y1=\"14\" y2=\"11\"></line><circle cx=\"12\" cy=\"14\" r=\"8\"></circle></svg></div><h3 class=\"text-slate-100 mb-2 tracking-wide relative z-10\">Operational Delays</h3></div></div><div class=\"absolute top-full left-1/2 -translate-x-1/2 mt-4 w-64 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none z-20\"><div class=\"bg-slate-950/95 backdrop-blur-md border rounded-lg p-4 shadow-2xl\"><div class=\"absolute -top-2 left-1/2 -translate-x-1/2 w-4 h-4 rotate-45\"></div><p class=\"text-slate-300 text-sm relative z-10\">later...</p></div></div></div><div class=\"relative w-50 aspect-square group\"><div class=\"\n            absolute inset-0\n            bg-slate-900/50\n            backdrop-blur-m\n            transition-all\n            duration-300\n            overflow-hidden\n            border-2 border-cyan-400\n            flex justify-center items-center\n            rotate-45\n          \" style=\"clip-path:polygon(30% 0%, 70% 0%, 100% 30%, 100% 70%, 70% 100%, 30% 100%, 0% 70%, 0% 30%)\"></div><div class=\"   absolute inset-0   flex flex-col items-center justify-center p-6 text-center   rotate-45 group   \" style=\"clip-path:polygon(30% 0%, 70% 0%, 100% 30%, 100% 70%, 70% 100%, 30% 100%, 0% 70%, 0% 30%)\"><div class=\"\n              absolute inset-0\n              bg-gradient-to-b from-transparent via-white/5 to-transparent -translate-y-full\n              group-hover:translate-y-full \n              transition-transform duration-1000\n              pointer-events-none\n            \"></div><div class=\"-rotate-45 flex flex-col items-center justify-center\"><div class=\"w-14 h-14 bg-cyan-500/10 rounded-full flex items-center justify-center mb-3 border border-current/20 relative z-10\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-triangle-alert w-7 h-7 text-cyan-400\" aria-hidden=\"true\"><path d=\"m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3\"></path><path d=\"M12 9v4\"></path><path d=\"M12 17h.01\"></path></svg></div><h3 class=\"text-slate-100 mb-2 tracking-wide relative z-10\">Security Risks</h3></div></div><div class=\"absolute top-full left-1/2 -translate-x-1/2 mt-4 w-64 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none z-20\"><div class=\"bg-slate-950/95 backdrop-blur-md border rounded-lg p-4 shadow-2xl\"><div class=\"absolute -top-2 left-1/2 -translate-x-1/2 w-4 h-4 rotate-45\"></div><p class=\"text-slate-300 text-sm relative z-10\">later...</p></div></div></div><div class=\"relative w-50 aspect-square group\"><div class=\"\n            absolute inset-0\n            bg-slate-900/50\n            backdrop-blur-m\n            transition-all\n            duration-300\n            overflow-hidden\n            border-2 border-cyan-400\n            flex justify-center items-center\n            rotate-45\n          \" style=\"clip-path:polygon(30% 0%, 70% 0%, 100% 30%, 100% 70%, 70% 100%, 30% 100%, 0% 70%, 0% 30%)\"></div><div class=\"   absolute inset-0   flex flex-col items-center justify-center p-6 text-center   rotate-45 group   \" style=\"clip-path:polygon(30% 0%, 70% 0%, 100% 30%, 100% 70%, 70% 100%, 30% 100%, 0% 70%, 0% 30%)\"><div class=\"\n              absolute inset-0\n              bg-gradient-to-b from-transparent via-white/5 to-transparent -translate-y-full\n              group-hover:translate-y-full \n              transition-transform duration-1000\n              pointer-events-none\n            \"></div><div class=\"-rotate-45 flex flex-col items-center justify-center\"><div class=\"w-14 h-14 bg-cyan-500/10 rounded-full flex items-center justify-center mb-3 border border-current/20 relative z-10\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-wrench w-7 h-7 text-cyan-400\" aria-hidden=\"true\"><path d=\"M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.106-3.105c.32-.322.863-.22.983.218a6 6 0 0 1-8.259 7.057l-7.91 7.91a1 1 0 0 1-2.999-3l7.91-7.91a6 6 0 0 1 7.057-8.259c.438.12.54.662.219.984z\"></path></svg></div><h3 class=\"text-slate-100 mb-2 tracking-wide relative z-10\">High Maintenance</h3></div></div><div class=\"absolute top-full left-1/2 -translate-x-1/2 mt-4 w-64 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none z-20\"><div class=\"bg-slate-950/95 backdrop-blur-md border rounded-lg p-4 shadow-2xl\"><div class=\"absolute -top-2 left-1/2 -translate-x-1/2 w-4 h-4 rotate-45\"></div><p class=\"text-slate-300 text-sm relative z-10\">later...</p></div></div></div></div></div></section><section id=\"\" class=\"flex flex-col items-center p-6 min-h-screen \"><div class=\"mb-20\"><div class=\"grid md:grid-cols-2 gap-12 items-center mx-10\"><div><div class=\"text-cyan-500 tracking-[0.2em] text-xs mb-6 uppercase flex items-center gap-3\"><div class=\"w-8 h-px bg-gradient-to-r from-transparent to-cyan-500\"></div>The Solution<div class=\"w-8 h-px bg-gradient-to-l from-transparent to-cyan-500\"></div></div><div class=\"mb-8\"><h1 class=\"text-white mb-0 text-4xl md:text-6xl lg:text-7xl\">Vein Driven</h1><div class=\"relative inline-block\"><h1 class=\"text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 via-cyan-300 to-cyan-500 text-5xl md:text-7xl lg:text-8xl animate-pulse mb-0\">Precision.</h1></div></div><div><p class=\"text-slate-300 mb-6\">Transcending the basic scanner, Z-TAS is a palm-vein biometric engine built for high-throughput environments where milliseconds define efficiency.</p><p class=\"text-slate-400\">The system reads subcutaneous vein topology using near-infrared sensors, encrypts the data at the edge, and validates identity through cloud infrastructure—eliminating physical tokens, shared surfaces, and authentication latency.</p></div></div><div class=\"relative group mx-10 \"><div class=\"absolute inset-0 overflow-hidden rounded-xl z-20 pointer-events-none h-full w-full animate-slide\"><div class=\"absolute w-full h-1 bg-gradient-to-r from-transparent via-cyan-400 to-transparent\"></div></div><div class=\"absolute bg-black w-full h-full mix-blend-overlay z-1 opacity-75\"></div><div class=\"absolute top-4 left-4 text-cyan-400 text-xs font-mono\"><div class=\"flex items-center gap-2 mb-1\"><div class=\"w-2 h-2 bg-cyan-400 rounded-full animate-pulse\"></div><span>SCANNING ACTIVE</span></div><div class=\"text-cyan-500/100\">NIR_SENSOR_01</div></div><div class=\"relative flex items-center justify-center\"><img src=\"Assets/veinless-scan.png\" alt=\"Vein Scan Image\" class=\"   w-[70%]    object-cover    block inset-0      \"/><img src=\"Assets/vein-scan.png\" alt=\"Vein Scan Image\" class=\"   w-[70%]    object-cover   block absolute inset-0    top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2   animate-slide-mask   \" style=\"-webkit-mask-image:url(/Assets/solid-color-image.png);-webkit-mask-repeat:no-repeat;-webkit-mask-position:center;-webkit-mask-size:100% 20%;mask-image:url(/Assets/solid-color-image.png);mask-repeat:no-repeat;mask-position:0% 80%;mask-size:100% 20%\"/></div><div class=\"absolute bottom-4 right-4 text-right text-xs font-mono\"><div class=\"text-cyan-400 mb-1\">MATCH: 99.97%</div><div class=\"text-cyan-500/100\">AUTH_VERIFIED</div></div><div class=\"absolute top-0 left-0 w-8 h-8 border-t-2 border-l-2 border-cyan-400\"></div><div class=\"absolute top-0 right-0 w-8 h-8 border-t-2 border-r-2 border-cyan-400\"></div><div class=\"absolute bottom-0 left-0 w-8 h-8 border-b-2 border-l-2 border-cyan-400\"></div><div class=\"absolute bottom-0 right-0 w-8 h-8 border-b-2 border-r-2 border-cyan-400\"></div></div></div></div><div class=\"mb-12 w-full\"><div class=\"flex items-center gap-3 mb-8\"><div class=\"   h-px flex-1   bg-gradient-to-r from-transparent via-cyan-500/50 to-transparent   \"></div><h2 class=\"   text-transparent    bg-clip-text    bg-gradient-to-r from-cyan-500 to-purple-500    uppercase    tracking-wider   \">Core Architecture</h2><div class=\"h-px flex-1 bg-gradient-to-r from-transparent via-cyan-500/50 to-transparent\"></div></div></div><div class=\"grid grid-cols-3 w-[90%] gap-10 flex-wrap\"><div class=\"flex-1 \"><div class=\"bg-slate-900/50 backdrop-blur-sm rounded-xl p-6 border border-cyan-500/30 shadow-[0_0_30px_rgba(6,182,212,0.3)] hover:shadow-[0_0_50px_rgba(6,182,212,0.5)] hover:border-cyan-500/60 transition-all duration-300 group\"><div class=\"flex items-start justify-between mb-4\"><div class=\"bg-gradient-to-br from-cyan-500/20 to-cyan-600/20 w-12 h-12 rounded-lg flex items-center justify-center border border-cyan-500/50 shadow-[0_0_20px_rgba(6,182,212,0.4)]\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-hand w-6 h-6 text-cyan-400\" aria-hidden=\"true\"><path d=\"M18 11V6a2 2 0 0 0-2-2a2 2 0 0 0-2 2\"></path><path d=\"M14 10V4a2 2 0 0 0-2-2a2 2 0 0 0-2 2v2\"></path><path d=\"M10 10.5V6a2 2 0 0 0-2-2a2 2 0 0 0-2 2v8\"></path><path d=\"M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15\"></path></svg></div><div class=\"text-right\"><div class=\"text-xs text-cyan-500 tracking-wider uppercase mb-1\">Mode</div><div class=\"text-white\">Contactless</div></div></div><h3 class=\"text-cyan-100 mb-3\">Zero-Touch Interface</h3><p class=\"text-slate-400 text-sm mb-4\">Hover-detection with proximity sensors. No physical contact, no contamination vectors, no bottlenecks.</p><div class=\"pt-3 border-t border-cyan-500/20\"><div class=\"flex justify-between text-xs\"><span class=\"text-slate-500\">Detection Range</span><span class=\"text-cyan-400\">5-15cm</span></div></div></div></div><div class=\"flex-1 \"><div class=\"bg-slate-900/50 backdrop-blur-sm rounded-xl p-6 border border-cyan-500/30 shadow-[0_0_30px_rgba(6,182,212,0.3)] hover:shadow-[0_0_50px_rgba(6,182,212,0.5)] hover:border-cyan-500/60 transition-all duration-300 group\"><div class=\"flex items-start justify-between mb-4\"><div class=\"bg-gradient-to-br from-cyan-500/20 to-cyan-600/20 w-12 h-12 rounded-lg flex items-center justify-center border border-cyan-500/50 shadow-[0_0_20px_rgba(6,182,212,0.4)]\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-cloud w-6 h-6 text-cyan-400\" aria-hidden=\"true\"><path d=\"M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z\"></path></svg></div><div class=\"text-right\"><div class=\"text-xs text-cyan-500 tracking-wider uppercase mb-1\"></div><div class=\"text-white\"></div></div></div><h3 class=\"text-cyan-100 mb-3\">Cloud-Native Verification</h3><p class=\"text-slate-400 text-sm mb-4\">i dunno what to add here for now, later...</p><div class=\"pt-3 border-t border-cyan-500/20\"><div class=\"flex justify-between text-xs\"><span class=\"text-slate-500\">Encryption</span><span class=\"text-cyan-400\"></span></div></div></div></div><div class=\"flex-1 \"><div class=\"bg-slate-900/50 backdrop-blur-sm rounded-xl p-6 border border-cyan-500/30 shadow-[0_0_30px_rgba(6,182,212,0.3)] hover:shadow-[0_0_50px_rgba(6,182,212,0.5)] hover:border-cyan-500/60 transition-all duration-300 group\"><div class=\"flex items-start justify-between mb-4\"><div class=\"bg-gradient-to-br from-cyan-500/20 to-cyan-600/20 w-12 h-12 rounded-lg flex items-center justify-center border border-cyan-500/50 shadow-[0_0_20px_rgba(6,182,212,0.4)]\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-shield w-6 h-6 text-cyan-400\" aria-hidden=\"true\"><path d=\"M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z\"></path></svg></div><div class=\"text-right\"><div class=\"text-xs text-cyan-500 tracking-wider uppercase mb-1\">FAR</div><div class=\"text-white\">&lt;0.0001%</div></div></div><h3 class=\"text-cyan-100 mb-3\">Immutable Audit Trail</h3><p class=\"text-slate-400 text-sm mb-4\">Cryptographically signed access logs with tamper-proof timestamping. Full accountability with zero data loss.</p><div class=\"pt-3 border-t border-cyan-500/20\"><div class=\"flex justify-between text-xs\"><span class=\"text-slate-500\">Retention</span><span class=\"text-cyan-400\">Indefinite</span></div></div></div></div></div></section><section class=\"relative w-full bg-zinc-950 text-white py-24 px-6 overflow-hidden\"><div class=\"absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[500px] bg-blue-900/20 blur-[120px] rounded-full pointer-events-none\"></div><div class=\"max-w-7xl mx-auto z-10 relative\"><div class=\"mb-20 text-center md:text-left\"><h2 class=\"text-sm font-mono text-blue-400 tracking-widest uppercase mb-4\">Under the Hood</h2><h1 class=\"text-5xl md:text-7xl font-bold tracking-tight text-white mb-6\">Engineered for <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-emerald-400\">Security.</span></h1><p class=\"text-zinc-400 text-lg md:text-xl max-w-2xl leading-relaxed\">Z-TAS isn&#x27;t just a camera. It&#x27;s a synchronized array of sensors and compute modules designed to capture vascular patterns with clinical precision.</p></div><div class=\"flex flex-col lg:flex-row gap-12 lg:gap-24\"><div class=\"hidden lg:block w-1/3 relative\"><div class=\"sticky top-24\"><div class=\"aspect-[4/5] bg-zinc-900 rounded-3xl border border-zinc-800 p-8 flex flex-col justify-between overflow-hidden relative group\"><div class=\"absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(59,130,246,0.1),transparent_70%)]\"></div><div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-48 h-48 rounded-full border border-blue-500/30 flex items-center justify-center animate-pulse\"><div class=\"w-32 h-32 rounded-full border border-emerald-500/30\"></div></div><div class=\"relative z-10\"><span class=\"text-xs font-mono text-zinc-500\">SYSTEM ARCHITECTURE</span></div><div class=\"relative z-10\"><h3 class=\"text-3xl font-bold text-white mb-2\">Vision System</h3><p class=\"text-zinc-400 text-sm\">Precision hardware components working in unison to deliver low-FAR authorization.</p></div></div></div></div><div class=\"w-full lg:w-2/3\"><div class=\"space-y-16\"><div class=\"group\"><h3 class=\"text-2xl font-semibold text-white mb-8 pl-4 border-l-2 border-blue-500\">Vision System</h3><div class=\"grid grid-cols-1 gap-4\"><div class=\"   group relative flex items-center justify-between   p-6 rounded-xl   bg-zinc-900/40 border border-white/5   hover:bg-zinc-800/60 hover:border-white/10   transition-all duration-300 ease-out   \"><div class=\"flex items-start gap-5\"><div class=\"   p-3 rounded-lg bg-zinc-950 border border-zinc-800    text-zinc-400 group-hover:text-blue-400 group-hover:border-blue-500/30   transition-colors duration-300   \"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-eye w-5 h-5\" aria-hidden=\"true\"><path d=\"M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0\"></path><circle cx=\"12\" cy=\"12\" r=\"3\"></circle></svg></div><div><h4 class=\"text-lg font-medium text-white mb-1 group-hover:text-blue-200 transition-colors\">NIR Optical Module</h4><p class=\"text-sm text-zinc-400 max-w-md leading-relaxed\">Captures subcutaneous vein patterns invisible to the naked eye.</p></div></div><div class=\"hidden sm:block text-right\"><span class=\"text-xs font-mono text-zinc-600 uppercase tracking-wider block mb-1\">Spec</span><span class=\"text-sm font-bold text-zinc-300 group-hover:text-white\">850nm</span></div></div><div class=\"   group relative flex items-center justify-between   p-6 rounded-xl   bg-zinc-900/40 border border-white/5   hover:bg-zinc-800/60 hover:border-white/10   transition-all duration-300 ease-out   \"><div class=\"flex items-start gap-5\"><div class=\"   p-3 rounded-lg bg-zinc-950 border border-zinc-800    text-zinc-400 group-hover:text-blue-400 group-hover:border-blue-500/30   transition-colors duration-300   \"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-zap w-5 h-5\" aria-hidden=\"true\"><path d=\"M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z\"></path></svg></div><div><h4 class=\"text-lg font-medium text-white mb-1 group-hover:text-blue-200 transition-colors\">Intelligent LED Array</h4><p class=\"text-sm text-zinc-400 max-w-md leading-relaxed\">Adaptive infrared illumination for varied lighting conditions.</p></div></div><div class=\"hidden sm:block text-right\"><span class=\"text-xs font-mono text-zinc-600 uppercase tracking-wider block mb-1\">Spec</span><span class=\"text-sm font-bold text-zinc-300 group-hover:text-white\">Adaptive</span></div></div><div class=\"   group relative flex items-center justify-between   p-6 rounded-xl   bg-zinc-900/40 border border-white/5   hover:bg-zinc-800/60 hover:border-white/10   transition-all duration-300 ease-out   \"><div class=\"flex items-start gap-5\"><div class=\"   p-3 rounded-lg bg-zinc-950 border border-zinc-800    text-zinc-400 group-hover:text-blue-400 group-hover:border-blue-500/30   transition-colors duration-300   \"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-camera w-5 h-5\" aria-hidden=\"true\"><path d=\"M13.997 4a2 2 0 0 1 1.76 1.05l.486.9A2 2 0 0 0 18.003 7H20a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2h1.997a2 2 0 0 0 1.759-1.048l.489-.904A2 2 0 0 1 10.004 4z\"></path><circle cx=\"12\" cy=\"13\" r=\"3\"></circle></svg></div><div><h4 class=\"text-lg font-medium text-white mb-1 group-hover:text-blue-200 transition-colors\">RGB Alignment Sensor</h4><p class=\"text-sm text-zinc-400 max-w-md leading-relaxed\">Real-time hand tracking ensures perfect user positioning.</p></div></div><div class=\"hidden sm:block text-right\"><span class=\"text-xs font-mono text-zinc-600 uppercase tracking-wider block mb-1\">Spec</span><span class=\"text-sm font-bold text-zinc-300 group-hover:text-white\">1080p</span></div></div><div class=\"   group relative flex items-center justify-between   p-6 rounded-xl   bg-zinc-900/40 border border-white/5   hover:bg-zinc-800/60 hover:border-white/10   transition-all duration-300 ease-out   \"><div class=\"flex items-start gap-5\"><div class=\"   p-3 rounded-lg bg-zinc-950 border border-zinc-800    text-zinc-400 group-hover:text-blue-400 group-hover:border-blue-500/30   transition-colors duration-300   \"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-wifi w-5 h-5\" aria-hidden=\"true\"><path d=\"M12 20h.01\"></path><path d=\"M2 8.82a15 15 0 0 1 20 0\"></path><path d=\"M5 12.859a10 10 0 0 1 14 0\"></path><path d=\"M8.5 16.429a5 5 0 0 1 7 0\"></path></svg></div><div><h4 class=\"text-lg font-medium text-white mb-1 group-hover:text-blue-200 transition-colors\">ToF Proximity Field</h4><p class=\"text-sm text-zinc-400 max-w-md leading-relaxed\">Detects hand presence and triggers instant wake-up.</p></div></div><div class=\"hidden sm:block text-right\"><span class=\"text-xs font-mono text-zinc-600 uppercase tracking-wider block mb-1\">Spec</span><span class=\"text-sm font-bold text-zinc-300 group-hover:text-white\">&lt;20ms</span></div></div></div></div><div class=\"group\"><h3 class=\"text-2xl font-semibold text-white mb-8 pl-4 border-l-2 border-blue-500\">Core Processing</h3><div class=\"grid grid-cols-1 gap-4\"><div class=\"   group relative flex items-center justify-between   p-6 rounded-xl   bg-zinc-900/40 border border-white/5   hover:bg-zinc-800/60 hover:border-white/10   transition-all duration-300 ease-out   \"><div class=\"flex items-start gap-5\"><div class=\"   p-3 rounded-lg bg-zinc-950 border border-zinc-800    text-zinc-400 group-hover:text-blue-400 group-hover:border-blue-500/30   transition-colors duration-300   \"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-cpu w-5 h-5\" aria-hidden=\"true\"><path d=\"M12 20v2\"></path><path d=\"M12 2v2\"></path><path d=\"M17 20v2\"></path><path d=\"M17 2v2\"></path><path d=\"M2 12h2\"></path><path d=\"M2 17h2\"></path><path d=\"M2 7h2\"></path><path d=\"M20 12h2\"></path><path d=\"M20 17h2\"></path><path d=\"M20 7h2\"></path><path d=\"M7 20v2\"></path><path d=\"M7 2v2\"></path><rect x=\"4\" y=\"4\" width=\"16\" height=\"16\" rx=\"2\"></rect><rect x=\"8\" y=\"8\" width=\"8\" height=\"8\" rx=\"1\"></rect></svg></div><div><h4 class=\"text-lg font-medium text-white mb-1 group-hover:text-blue-200 transition-colors\">Neural Processing Board</h4><p class=\"text-sm text-zinc-400 max-w-md leading-relaxed\">On-device computation for immediate template matching.</p></div></div><div class=\"hidden sm:block text-right\"><span class=\"text-xs font-mono text-zinc-600 uppercase tracking-wider block mb-1\">Spec</span><span class=\"text-sm font-bold text-zinc-300 group-hover:text-white\">Quad-Core</span></div></div><div class=\"   group relative flex items-center justify-between   p-6 rounded-xl   bg-zinc-900/40 border border-white/5   hover:bg-zinc-800/60 hover:border-white/10   transition-all duration-300 ease-out   \"><div class=\"flex items-start gap-5\"><div class=\"   p-3 rounded-lg bg-zinc-950 border border-zinc-800    text-zinc-400 group-hover:text-blue-400 group-hover:border-blue-500/30   transition-colors duration-300   \"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-layers w-5 h-5\" aria-hidden=\"true\"><path d=\"M12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83z\"></path><path d=\"M2 12a1 1 0 0 0 .58.91l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9A1 1 0 0 0 22 12\"></path><path d=\"M2 17a1 1 0 0 0 .58.91l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9A1 1 0 0 0 22 17\"></path></svg></div><div><h4 class=\"text-lg font-medium text-white mb-1 group-hover:text-blue-200 transition-colors\">CSI High-Speed Bridge</h4><p class=\"text-sm text-zinc-400 max-w-md leading-relaxed\">Lossless data transmission between sensor and core.</p></div></div><div class=\"hidden sm:block text-right\"><span class=\"text-xs font-mono text-zinc-600 uppercase tracking-wider block mb-1\">Spec</span><span class=\"text-sm font-bold text-zinc-300 group-hover:text-white\">Zero Latency</span></div></div></div></div><div class=\"group\"><h3 class=\"text-2xl font-semibold text-white mb-8 pl-4 border-l-2 border-blue-500\">Chassis &amp; Thermal</h3><div class=\"grid grid-cols-1 gap-4\"><div class=\"   group relative flex items-center justify-between   p-6 rounded-xl   bg-zinc-900/40 border border-white/5   hover:bg-zinc-800/60 hover:border-white/10   transition-all duration-300 ease-out   \"><div class=\"flex items-start gap-5\"><div class=\"   p-3 rounded-lg bg-zinc-950 border border-zinc-800    text-zinc-400 group-hover:text-blue-400 group-hover:border-blue-500/30   transition-colors duration-300   \"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-thermometer w-5 h-5\" aria-hidden=\"true\"><path d=\"M14 4v10.54a4 4 0 1 1-4 0V4a2 2 0 0 1 4 0Z\"></path></svg></div><div><h4 class=\"text-lg font-medium text-white mb-1 group-hover:text-blue-200 transition-colors\">Active Cooling Loop</h4><p class=\"text-sm text-zinc-400 max-w-md leading-relaxed\">Maintains optimal sensor temperature for consistent accuracy.</p></div></div><div class=\"hidden sm:block text-right\"><span class=\"text-xs font-mono text-zinc-600 uppercase tracking-wider block mb-1\">Spec</span><span class=\"text-sm font-bold text-zinc-300 group-hover:text-white\">Silent</span></div></div><div class=\"   group relative flex items-center justify-between   p-6 rounded-xl   bg-zinc-900/40 border border-white/5   hover:bg-zinc-800/60 hover:border-white/10   transition-all duration-300 ease-out   \"><div class=\"flex items-start gap-5\"><div class=\"   p-3 rounded-lg bg-zinc-950 border border-zinc-800    text-zinc-400 group-hover:text-blue-400 group-hover:border-blue-500/30   transition-colors duration-300   \"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-shield-check w-5 h-5\" aria-hidden=\"true\"><path d=\"M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z\"></path><path d=\"m9 12 2 2 4-4\"></path></svg></div><div><h4 class=\"text-lg font-medium text-white mb-1 group-hover:text-blue-200 transition-colors\">Polymer Matrix Shell</h4><p class=\"text-sm text-zinc-400 max-w-md leading-relaxed\">Custom 3D-fabricated housing for durability and ergonomics.</p></div></div><div class=\"hidden sm:block text-right\"><span class=\"text-xs font-mono text-zinc-600 uppercase tracking-wider block mb-1\">Spec</span><span class=\"text-sm font-bold text-zinc-300 group-hover:text-white\">Rugged</span></div></div></div></div></div></div></div></div></section><div class=\"min-h-screen bg-black flex flex-col items-center justify-center p-4 md:p-8 font-sans\"><div class=\"mb-8 text-center space-y-2\"><div class=\"inline-block px-3 py-1 rounded-full bg-[#086CB4]/10 border    border-[#086CB4]/30 text-[#086CB4] text-xs font-mono tracking-widest uppercase mb-4\">Interactive Bull Shi</div></div><div class=\"flex flex-col items-center w-full max-w-5xl mx-auto space-y-8\"><div class=\"relative w-full max-w-lg h-14 select-none\"><div class=\"absolute inset-0 bg-[#086CB4] blur-xl opacity-20\"></div><div class=\"relative w-full h-full bg-[#02040a] border border-[#086CB4]/50 shadow-inner overflow-hidden\" style=\"clip-path:polygon(3% 0%, 97% 0%, 100% 50%, 97% 100%, 3% 100%, 0% 50%)\"><div class=\"absolute top-0 bottom-0 w-32 transition-all duration-500 ease-out pointer-events-none\" style=\"left:10%;transform:translateX(-50%);background:radial-gradient(circle, rgba(8,108,180,0.6) 0%, rgba(8,108,180,0) 70%)\"></div><div class=\"absolute inset-0 flex\"><div class=\"flex-1 flex items-center justify-center cursor-pointer z-10\"><span class=\"text-[10px] md:text-xs font-bold tracking-[0.15em] transition-all duration-300 \n                  text-white drop-shadow-[0_0_8px_#086CB4] scale-105\">OVERVIEW</span></div><div class=\"flex-1 flex items-center justify-center cursor-pointer z-10\"><span class=\"text-[10px] md:text-xs font-bold tracking-[0.15em] transition-all duration-300 \n                  text-gray-600 hover:text-gray-400\">SPECS</span></div><div class=\"flex-1 flex items-center justify-center cursor-pointer z-10\"><span class=\"text-[10px] md:text-xs font-bold tracking-[0.15em] transition-all duration-300 \n                  text-gray-600 hover:text-gray-400\">FEATURES</span></div></div></div><div class=\"absolute top-1/2 -translate-y-1/2 w-12 h-12 z-20 pointer-events-none transition-all \n            duration-500 cubic-bezier(0.4, 0, 0.2, 1) flex items-center justify-center\n            left-[5%]\"><div class=\"absolute inset-0 bg-[#086CB4] blur-md opacity-60 animate-pulse\" style=\"clip-path:polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%)\"></div><div class=\"w-full h-full bg-gradient-to-br from-[#086CB4] to-[#02040a] border    border-[#086CB4] shadow-[0_0_15px_rgba(8,108,180,0.5)] flex items-center justify-center\" style=\"clip-path:polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%)\"><div class=\"w-3 h-3 bg-white shadow-[0_0_10px_white]\" style=\"transform:rotate(45deg)\"></div></div></div></div><div class=\"w-full transition-all duration-500 ease-in-out\"><div class=\"relative group w-full animate-in fade-in zoom-in duration-500\"><div class=\"absolute -inset-1 bg-gradient-to-r from-[#06426D] via-[#086CB4]    to-[#06426D] rounded-2xl opacity-10 blur-xl group-hover:opacity-20 transition duration-1000\"></div><div class=\"relative p-[1px] bg-gradient-to-b from-[#086CB4]/40 via-[#06426D]/20 to-transparent rounded-2xl\"><div class=\"relative bg-[#02040a] rounded-2xl overflow-hidden shadow-2xl min-h-[400px] flex flex-col\"><div class=\"w-full h-1 bg-gradient-to-r from-[#086CB4] via-white/20 to-[#086CB4]\"></div><div class=\"p-6 md:p-10 flex flex-col h-full\"><div class=\"text-center mb-10\"><h3 class=\"text-2xl md:text-3xl font-bold text-white tracking-wide mb-2 drop-shadow-md\">Secure<!-- --> <span class=\"text-[#086CB4]\"> <!-- -->Biometric Architecture<!-- --> </span></h3><div class=\"h-1 w-24 bg-[#086CB4]/30 mx-auto rounded-full\"></div></div><p class=\"text-xs text-gray-500 uppercase tracking-[0.2em] font-mono \">Zero-Touch Authentication Flow</p><div class=\"\"></div><div class=\"space-y-6 max-w-2xl mx-auto w-full\"><div class=\"flex group/step\"><div class=\"flex flex-col items-center mr-6\"><div class=\"w-10 h-10 rounded-full bg-[#086CB4]/10 border border-[#086CB4]/30 flex items-center justify-center group-hover/step:bg-[#086CB4]/20 group-hover/step:border-[#086CB4] transition-all shadow-[0_0_15px_rgba(8,108,180,0.1)]\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-fingerprint-pattern w-5 h-5 text-[#086CB4]\" aria-hidden=\"true\"><path d=\"M12 10a2 2 0 0 0-2 2c0 1.02-.1 2.51-.26 4\"></path><path d=\"M14 13.12c0 2.38 0 6.38-1 8.88\"></path><path d=\"M17.29 21.02c.12-.6.43-2.3.5-3.02\"></path><path d=\"M2 12a10 10 0 0 1 18-6\"></path><path d=\"M2 16h.01\"></path><path d=\"M21.8 16c.2-2 .131-5.354 0-6\"></path><path d=\"M5 19.5C5.5 18 6 15 6 12a6 6 0 0 1 .34-2\"></path><path d=\"M8.65 22c.21-.66.45-1.32.57-2\"></path><path d=\"M9 6.8a6 6 0 0 1 9 5.2v2\"></path></svg></div><div class=\"w-0.5 h-full bg-gradient-to-b from-[#086CB4]/30 to-transparent my-2\"></div></div><div class=\"pb-8\"><h4 class=\"text-white font-bold text-lg mb-1 flex items-center gap-2\">Noised Biometric Hashing<span class=\"px-2 py-0.5 rounded text-[10px] bg-[#06426D]/30 border border-[#06426D] text-[#086CB4]\">NIR Scan</span></h4><p class=\"text-gray-400 text-sm leading-relaxed font-light\">Palm vein &amp; print templates are generated, injected with noise for entropy, and hashed. Stored securely using <span class=\"text-[#086CB4] font-medium\">Homomorphic Encryption</span> within a Secure Enclave.</p></div></div><div class=\"flex group/step\"><div class=\"flex flex-col items-center mr-6\"><div class=\"w-10 h-10 rounded-full bg-[#086CB4]/10 border border-[#086CB4]/30 flex items-center justify-center group-hover/step:bg-[#086CB4]/20 group-hover/step:border-[#086CB4] transition-all shadow-[0_0_15px_rgba(8,108,180,0.1)]\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-shield-check w-5 h-5 text-[#086CB4]\" aria-hidden=\"true\"><path d=\"M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z\"></path><path d=\"m9 12 2 2 4-4\"></path></svg></div><div class=\"w-0.5 h-full bg-gradient-to-b from-[#086CB4]/30 to-transparent my-2\"></div></div><div class=\"pb-8\"><h4 class=\"text-white font-bold text-lg mb-1\">Post-Quantum Tunnel</h4><p class=\"text-gray-400 text-sm leading-relaxed font-light\">Auth requests are transmitted via a quantum-secure tunnel.<br/><span class=\"font-mono text-xs text-[#086CB4] opacity-80 mt-1 block\">• Key Exchange: Kyber   |   Signature: Dilithium</span></p></div></div><div class=\"flex group/step\"><div class=\"flex flex-col items-center mr-6\"><div class=\"w-10 h-10 rounded-full bg-[#086CB4]/10 border border-[#086CB4]/30 flex items-center justify-center group-hover/step:bg-[#086CB4]/20 group-hover/step:border-[#086CB4] transition-all shadow-[0_0_15px_rgba(8,108,180,0.1)]\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-blocks w-5 h-5 text-[#086CB4]\" aria-hidden=\"true\"><path d=\"M10 22V7a1 1 0 0 0-1-1H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-5a1 1 0 0 0-1-1H2\"></path><rect x=\"14\" y=\"2\" width=\"8\" height=\"8\" rx=\"1\"></rect></svg></div></div><div><h4 class=\"text-white font-bold text-lg mb-1\">MFA &amp; Blockchain Audit</h4><p class=\"text-gray-400 text-sm leading-relaxed font-light\">Upon hash match, MFA is triggered. Successful auth grants access and writes an immutable audit trail to the blockchain.</p></div></div></div><div class=\"mt-8 flex justify-center\"><div class=\"px-6 py-2 rounded-full bg-gradient-to-r from-[#086CB4]/10 to-[#06426D]/10 border border-[#086CB4]/30 flex items-center gap-2\"><div class=\"w-2 h-2 bg-[#086CB4] rounded-full animate-pulse\"></div><span class=\"text-xs font-bold text-[#086CB4] tracking-widest uppercase\">System Operational</span></div></div></div></div></div></div></div></div></div><div class=\"min-h-screen bg-black flex items-center justify-center p-8\"><div class=\"flex flex-col md:flex-row items-stretch justify-center gap-6\"><div class=\"w-full md:w-80 lg:w-96 flex-none flex flex-col\"><div class=\"relative h-full p-8 bg-gray-950 rounded-[2rem] border border-blue-900/50 shadow-[0_0_50px_-12px_rgba(37,99,235,0.6)] flex flex-col items-center text-center group transition-transform hover:scale-[1.02]\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-hand w-24 h-24 text-blue-500 mb-6 stroke-[1.5px] drop-shadow-[0_0_10px_rgba(59,130,246,0.4)]\" aria-hidden=\"true\"><path d=\"M18 11V6a2 2 0 0 0-2-2a2 2 0 0 0-2 2\"></path><path d=\"M14 10V4a2 2 0 0 0-2-2a2 2 0 0 0-2 2v2\"></path><path d=\"M10 10.5V6a2 2 0 0 0-2-2a2 2 0 0 0-2 2v8\"></path><path d=\"M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15\"></path></svg><h3 class=\"text-white text-2xl font-bold mb-4 tracking-wide\">1. Capture &amp; Stabilization</h3><p class=\"text-gray-400 text-lg leading-relaxed flex-grow\">The NIR Camera captures the unique vain patter</p></div></div><div class=\"hidden md:flex self-center\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-right w-12 h-12 text-blue-500 animate-pulse\" aria-hidden=\"true\"><path d=\"m9 18 6-6-6-6\"></path></svg></div><div class=\"w-full md:w-80 lg:w-96 flex-none flex flex-col\"><div class=\"relative h-full p-8 bg-gray-950 rounded-[2rem] border border-blue-900/50 shadow-[0_0_50px_-12px_rgba(37,99,235,0.6)] flex flex-col items-center text-center group transition-transform hover:scale-[1.02]\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-settings w-24 h-24 text-blue-500 mb-6 stroke-[1.5px] drop-shadow-[0_0_10px_rgba(59,130,246,0.4)]\" aria-hidden=\"true\"><path d=\"M9.671 4.136a2.34 2.34 0 0 1 4.659 0 2.34 2.34 0 0 0 3.319 1.915 2.34 2.34 0 0 1 2.33 4.033 2.34 2.34 0 0 0 0 3.831 2.34 2.34 0 0 1-2.33 4.033 2.34 2.34 0 0 0-3.319 1.915 2.34 2.34 0 0 1-4.659 0 2.34 2.34 0 0 0-3.32-1.915 2.34 2.34 0 0 1-2.33-4.033 2.34 2.34 0 0 0 0-3.831A2.34 2.34 0 0 1 6.35 6.051a2.34 2.34 0 0 0 3.319-1.915\"></path><circle cx=\"12\" cy=\"12\" r=\"3\"></circle></svg><h3 class=\"text-white text-2xl font-bold mb-4 tracking-wide\">2. Geometry Extraction &amp; Hashing</h3><p class=\"text-gray-400 text-lg leading-relaxed flex-grow\">Converted through geometry extraction, noise reduction and cryptographic hashing</p></div></div><div class=\"hidden md:flex self-center\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-right w-12 h-12 text-blue-500 animate-pulse\" aria-hidden=\"true\"><path d=\"m9 18 6-6-6-6\"></path></svg></div><div class=\"w-full md:w-80 lg:w-96 flex-none flex flex-col\"><div class=\"relative h-full p-8 bg-gray-950 rounded-[2rem] border border-blue-900/50 shadow-[0_0_50px_-12px_rgba(37,99,235,0.6)] flex flex-col items-center text-center group transition-transform hover:scale-[1.02]\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-lock w-24 h-24 text-blue-500 mb-6 stroke-[1.5px] drop-shadow-[0_0_10px_rgba(59,130,246,0.4)]\" aria-hidden=\"true\"><rect width=\"18\" height=\"11\" x=\"3\" y=\"11\" rx=\"2\" ry=\"2\"></rect><path d=\"M7 11V7a5 5 0 0 1 10 0v4\"></path></svg><h3 class=\"text-white text-2xl font-bold mb-4 tracking-wide\">3. Template Secure</h3><p class=\"text-gray-400 text-lg leading-relaxed flex-grow\">The final domestic template is prepared for and storage</p></div></div></div></div><section class=\"relative w-full flex items-center justify-center my-16\"><div class=\"absolute top-0 left-[3%]\"><div class=\"flex gap-6\"><div class=\"w-1 bg-blue-700 rounded-full\"></div><div class=\"space-y-2\"><p class=\"uppercase tracking-widest text-xs text-gray-400 leading-none\">hoomans...</p><span class=\"text-5xl font-sem